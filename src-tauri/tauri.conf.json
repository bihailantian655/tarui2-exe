{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "BAT_R",
  "version": "1.0.0",
  "identifier": "com.example.bat-r",
  "build": {
    "beforeDevCommand": "npm run preview",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:8080"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BAT_R",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
